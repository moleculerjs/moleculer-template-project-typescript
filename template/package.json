{
  "name": "{{projectName}}",
  "version": "1.0.0",
  "description": "My Moleculer-based microservices project",
  "type": "module",
  "scripts": {
    "build": "tsc --project tsconfig.build.json || cd .",
    "postbuild": "echo {\"type\": \"commonjs\"} > dist/package.json",
    "dev": "tsx ./node_modules/moleculer/bin/moleculer-runner.js --config moleculer.config.ts --hot --repl services/**/*.service.ts",
    "start": "moleculer-runner --config dist/moleculer.config.js",
    "cli": "moleculer connect {{transporter}}",
    "ci": "vitest --watch",
    "test": "vitest --run --coverage"{{#lint}},
    "lint": "eslint",
    "lint:fix": "eslint --fix"{{/lint}}{{#docker}},
    "dc:up": "docker compose up --build -d",
    "dc:logs": "docker compose logs -f",
    "dc:down": "docker compose down"{{/docker}}
  },
  "keywords": [
    "microservices",
    "moleculer"
  ],
  "author": "",
  "devDependencies": {
    "@types/node": "^22.17.1",
    {{#lint}}
		"@eslint/js": "^9.33.0",
    "eslint": "^9.33.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
		"typescript-eslint": "^8.39.0",
    "prettier": "^3.6.2",
    {{/lint}}
    {{#apiGW}}
    "supertest": "^7.1.4",
    {{/apiGW}}
    {{#apiIO}}
    "socket.io-client": "^4.8.1",
    {{/apiIO}}
    {{#apiGQL}}
    "graphql-request": "^6.1.0",
    {{/apiGQL}}
    "moleculer-repl": "^0.7.4",
		"tsx": "^4.20.3",
		"typescript": "^5.9.2",
		"vitest": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4"
  },
  "dependencies": {
    {{#apiGW}}
    "moleculer-web": "^0.11.0-beta2",
    {{/apiGW}}
    {{#dbService}}
    "@moleculer/database": "^0.3.0",
    "mongodb": "^6.18.0",
    "@seald-io/nedb": "^4.1.2",
    {{/dbService}}
    {{#nats}}
    "nats": "^2.29.3",
    {{/nats}}
    {{#if_eq transporter "MQTT"}}
    "mqtt": "^5.13.0",
    {{/if_eq}}
    {{#rabbitmq}}
    "amqplib": "^0.10.8",
    {{/rabbitmq}}
    {{#if_eq transporter "AMQP10"}}
    "rhea-promise": "^3.0.3",
    {{/if_eq}}
    {{#kafka}}
    "kafkajs": "^2.2.4",
    {{/kafka}}
    {{#redis}}
    "ioredis": "^5.7.0",
    {{/redis}}
    {{#apiGQL}}
    "graphql": "^16.11.0",
    "moleculer-apollo-server": "github:moleculerjs/moleculer-apollo-server#next",
    "graphql-type-json": "^0.3.2",
    {{/apiGQL}}
    {{#needChannels}}
    "@moleculer/channels": "^0.2.0",
    {{/needChannels}}
    {{#needWorkflows}}
    "@moleculer/workflows": "^0.1.1",
    {{/needWorkflows}}
    {{#apiIO}}
    "moleculer-io": "^2.2.0",
    {{/apiIO}}
    "moleculer": "github:moleculerjs/moleculer#next"
  },
  "engines": {
    "node": ">= 20.x.x"
  }
}
