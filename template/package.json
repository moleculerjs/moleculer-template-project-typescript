{
  "name": "{{projectName}}",
  "version": "1.0.0",
  "description": "My Moleculer-based microservices project",
  "type": "module",
  "scripts": {
    "build": "tsc --project tsconfig.build.json || cd .",
    "postbuild": "echo {\\\"type\\\": \\\"commonjs\\\"} > dist/package.json",
    "dev": "tsx ./node_modules/moleculer/bin/moleculer-runner.js --config moleculer.config.ts --hot --repl services/**/*.service.ts",
    "start": "moleculer-runner --config dist/moleculer.config.js",
    "cli": "moleculer connect {{transporter}}",
    "typecheck": "tsc --noEmit true",
    "ci": "vitest --watch",
    "test": "vitest --run --coverage"{{#lint}},
    "lint": "eslint",
    "lint:fix": "eslint --fix"{{/lint}}{{#docker}},
    "dc:up": "docker compose up --build -d",
    "dc:logs": "docker compose logs -f",
    "dc:down": "docker compose down"{{/docker}}
  },
  "keywords": [
    "microservices",
    "moleculer"
  ],
  "author": "",
  "devDependencies": {
    "@types/node": "^22.17.1",
    "@types/lodash": "^4.17.24",
    {{#lint}}
		"@eslint/js": "^9.33.0",
    "eslint": "^9.33.0",
    "globals": "^17.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
		"typescript-eslint": "^8.39.0",
    "prettier": "^3.8.1",
    {{/lint}}
    {{#apiGW}}
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    {{/apiGW}}
    {{#apiIO}}
    "socket.io-client": "^4.8.3",
    {{/apiIO}}
    {{#apiGQL}}
    "graphql-request": "^7.4.0",
    {{/apiGQL}}
    "moleculer-repl": "^0.8.0",
		"tsx": "^4.21.0",
		"typescript": "^5.9.2",
		"vitest": "^4.1.2",
    "@vitest/coverage-v8": "^4.1.2"
  },
  "dependencies": {
    {{#apiGW}}
    "moleculer-web": "^0.11.0",
    {{/apiGW}}
    {{#dbService}}
    "@moleculer/database": "^0.4.0",
    "mongodb": "^7.1.1",
    "@seald-io/nedb": "^4.1.2",
    {{/dbService}}
    {{#nats}}
    "nats": "^2.29.3",
    {{/nats}}
    {{#if_eq transporter "MQTT"}}
    "mqtt": "^5.15.1",
    {{/if_eq}}
    {{#rabbitmq}}
    "amqplib": "^1.0.2",
    {{/rabbitmq}}
    {{#if_eq transporter "AMQP10"}}
    "rhea-promise": "^3.0.3",
    {{/if_eq}}
    {{#kafka}}
    "@platformatic/kafka": "^1.18.0",
    {{/kafka}}
    {{#redis}}
    "ioredis": "^5.10.1",
    {{/redis}}
    {{#apiGQL}}
    "graphql": "^16.13.2",
    "moleculer-apollo-server": "^0.4.1",
    "graphql-type-json": "^0.3.2",
    {{/apiGQL}}
    {{#needChannels}}
    "@moleculer/channels": "^0.3.0",
    {{/needChannels}}
    {{#needWorkflows}}
    "@moleculer/workflows": "^0.2.1",
    {{/needWorkflows}}
    {{#apiIO}}
    "moleculer-io": "^3.0.0",
    {{/apiIO}}
    "lodash": "^4.17.23",
    "moleculer": "^0.15.0"
  },
  "engines": {
    "node": ">= 20.x.x"
  }
}
